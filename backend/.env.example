# ==============================================================================
# Scheme Mate Backend Configuration Template
# ==============================================================================

# Server Environment Mode (development | test | production)
NODE_ENV=development

# Server Listener Port
PORT=5000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=schememate

# JWT Token Security Settings
# In production, replace this secret with a long, cryptographically random key
JWT_SECRET=scheme_mate_super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d
